#include <iostream>
#include <string>
using namespace std;

class Producto {
private:
    string nombre;
    float precio;
    int stock;

public:
    Producto(string n, float p, int s) {
        nombre = n;
        precio = p;
        stock = s;
    }

    void aumentarStock(int cant) {
        stock += cant;
    }

    void disminuirStock(int cant) {
        stock -= cant;
    }
};

int main() { return 0; }
