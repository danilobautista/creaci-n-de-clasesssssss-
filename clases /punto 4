#include <iostream>
using namespace std;

class Rectangulo {
private:
    float largo;
    float ancho;

public:
    Rectangulo(float l, float a) {
        largo = l;
        ancho = a;
    }

    float area() {
        return largo * ancho;
    }

    float perimetro() {
        return 2 * (largo + ancho);
    }
};

int main() { return 0; }
