#include <iostream>
using namespace std;

class Circulo {
private:
    float radio;

public:
    Circulo(float r) {
        radio = r;
    }

    float area() {
        return 3.14 * radio * radio;
    }

    float circunferencia() {
        return 2 * 3.14 * radio;
    }
};

int main() { return 0; }
